---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout path="/">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Digital Marketing Agency</div>
      <h1>
        <span class="text-primary">Digital marketing</span> that keeps your pipeline full.
      </h1>
      <p class="hero-subtitle">
        We help businesses stop losing leads and start converting them. From automated outreach to AI-powered call handling, we build systems that grow your revenue.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Get a Free Consultation</a>
        <a href="/services" class="btn btn-outline btn-lg">View Our Services</a>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="problem-section section">
    <div class="container">
      <div class="section-header">
        <h2>The cost of lost leads is staggering.</h2>
        <p>Most businesses invest heavily in lead generation but neglect the follow-up. The result? Leads go cold, opportunities vanish, and ROI plummets.</p>
      </div>
      <div class="problem-grid">
        <div class="problem-item">
          <div class="problem-stat">400%</div>
          <div class="problem-label">Drop in odds of reaching a lead after just 5 minutes.</div>
          <div class="problem-source">Source: <a href="https://www.leadresponsemanagement.org/lrm_study/" target="_blank" rel="noopener">MIT/HBR Lead Response Study</a></div>
        </div>
        <div class="problem-item">
          <div class="problem-stat">80%</div>
          <div class="problem-label">Of leads go uncontacted or follow-up is abandoned within the first month.</div>
          <div class="problem-source">Source: <a href="https://www.marketingdonut.co.uk/resources/lead-generation-resources/lead-generation-strategy/quick-guide-to-lead-generation" target="_blank" rel="noopener">Marketing Donut / DMA</a></div>
        </div>
        <div class="problem-item">
          <div class="problem-stat">50%</div>
          <div class="problem-label">Of sales go to the first responder. Speed matters — and most businesses are too slow.</div>
          <div class="problem-source">Source: <a href="https://www.leadresponsemanagement.org/lrm_study/" target="_blank" rel="noopener">LRM/MIT Lead Response Study</a></div>
        </div>
        <div class="problem-item">
          <div class="problem-stat">3x</div>
          <div class="problem-label">More likely to close when nurtured with consistent, personalized follow-up.</div>
          <div class="problem-source">Source: <a href="https://www.nucleusresearch.com/research/notes/nu17-19-crm-roi/" target="_blank" rel="noopener">Nucleus Research CRM ROI</a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Full-funnel digital marketing services.</h2>
        <p>From lead capture to conversion, we deploy AI-powered systems and proven strategies to keep your business growing.</p>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="card-icon">LR</div>
          <h3 class="card-title">Automated Lead Reactivation</h3>
          <p class="card-text">Won back dormant contacts with automated, personalized outreach that re-engages past leads on autopilot.</p>
        </div>

        <div class="service-card">
          <div class="card-icon">RR</div>
          <h3 class="card-title">Reputation & Review Automation</h3>
          <p class="card-text">Build trust and social proof by automating review requests and managing your online reputation.</p>
        </div>

        <div class="service-card">
          <div class="card-icon">LN</div>
          <h3 class="card-title">Intelligent Lead Nurturing</h3>
          <p class="card-text">Keep your brand top-of-mind with smart, multi-channel nurture sequences that move leads to close.</p>
        </div>

        <div class="service-card">
          <div class="card-icon">CH</div>
          <h3 class="card-title">AI-Powered Call Handling</h3>
          <p class="card-text">Never miss a call again. Our AI receptionist answers, qualifies, and routes calls instantly.</p>
        </div>

        <div class="service-card">
          <div class="card-icon">PA</div>
          <h3 class="card-title">Performance Advertising</h3>
          <p class="card-text">Data-driven paid advertising campaigns that maximize ROI across Google, Meta, and more.</p>
        </div>

        <div class="service-card">
          <div class="card-icon">SEO</div>
          <h3 class="card-title">Search Engine Optimization</h3>
          <p class="card-text">Dominate search results and attract high-intent organic traffic that converts.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: var(--space-2xl);">
        <a href="/services" class="btn btn-outline btn-lg">View All 11 Services</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" style="background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container">
      <div class="section-header">
        <h2>Why businesses choose Lead Continuity.</h2>
        <p>We don't just run ads — we build end-to-end systems that capture, nurture, and convert leads.</p>
      </div>
      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-icon">AI</div>
          <div>
            <h4>AI-Powered Automation</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">Leverage artificial intelligence to handle repetitive tasks at scale while maintaining a personal touch.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">⚡</div>
          <div>
            <h4>Lightning-Fast Response</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">Respond to every lead within seconds, not hours. Speed-to-lead is the #1 factor in conversion.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">📊</div>
          <div>
            <h4>Data-Driven Results</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">Every campaign is tracked, measured, and optimized for maximum ROI. No guesswork.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">🔄</div>
          <div>
            <h4>End-to-End Funnel</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">From first touch to closed deal, we manage the entire customer journey so nothing falls through the cracks.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to stop losing leads?</h2>
      <p>Let's talk about how we can build a lead continuity system for your business.</p>
      <a href="/contact" class="btn btn-secondary btn-lg">Schedule Your Free Consultation</a>
    </div>
  </section>
</BaseLayout>
