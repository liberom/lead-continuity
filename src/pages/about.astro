---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us — Lead Continuity LLC"
  description="Learn about Lead Continuity LLC, our mission, founder Vinicius Libero Moreira, and how we help businesses grow through digital marketing."
  path="/about"
>
  <section class="about-hero">
    <div class="container">
      <h1>About <span class="text-primary">Lead Continuity</span></h1>
      <p style="font-size: var(--text-lg); max-width: 600px; margin: 0 auto;">We're on a mission to help businesses stop losing leads and start building predictable, scalable revenue pipelines.</p>
    </div>
  </section>

  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div>
          <h2>Our Story</h2>
          <p>Lead Continuity LLC was founded with a simple observation: most businesses invest heavily in generating leads but fail to follow up effectively. The result is a massive leak in the revenue pipeline.</p>
          <p>We set out to fix that. By combining AI-powered automation with proven digital marketing strategies, we build systems that capture every lead, nurture them intelligently, and convert them into paying customers — on autopilot.</p>
          <p>Today, we serve businesses across industries, from home services to professional services, e-commerce to SaaS. Our approach is niche-agnostic because great lead management is universal.</p>
        </div>
        <div class="founder-card">
          <img src="/assets/headshot.webp" alt="Vinicius Libero Moreira — Founder & CEO" class="founder-avatar-img" />
          <h3 class="founder-name">Vinicius Libero Moreira</h3>
          <p class="founder-title">Founder & CEO</p>
          <p style="font-size: var(--text-sm); color: var(--text-muted);">Vinicius is a digital marketing strategist and automation specialist with a passion for building systems that scale. He founded Lead Continuity to bring enterprise-level lead management to businesses of all sizes.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section alt">
    <div class="container">
      <div class="section-header">
        <h2>Our Mission</h2>
        <p>To empower businesses with intelligent marketing systems that ensure no lead is ever left behind — turning pipeline leaks into predictable revenue growth.</p>
      </div>
      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-icon">🎯</div>
          <div>
            <h4>Relentless Follow-Up</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">We believe every lead deserves a timely, personalized response. Our systems make that happen automatically.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">🤖</div>
          <div>
            <h4>AI-Powered Efficiency</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">We leverage artificial intelligence to do what humans can't — respond instantly, at scale, 24/7.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">📈</div>
          <div>
            <h4>Measurable Growth</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">Everything we build is tracked and optimized. You'll always know your ROI.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">🤝</div>
          <div>
            <h4>Partnership Approach</h4>
            <p style="font-size: var(--text-sm); color: var(--text-muted);">We don't just deliver services — we become an extension of your team, aligned with your growth goals.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section">
    <div class="container">
      <div class="section-header">
        <h2>Business Information</h2>
      </div>
      <div class="business-info">
        <dl>
          <dt>Legal Entity</dt>
          <dd>Lead Continuity LLC</dd>

          <dt>EIN</dt>
          <dd>[EIN PENDING]</dd>

          <dt>Address</dt>
          <dd>30 N Gould St Ste N, Sheridan, WY 82801</dd>

          <dt>Phone</dt>
          <dd><a href="tel:+13072964737">+1 (307) 296-4737</a></dd>

          <dt>Email</dt>
          <dd><a href="mailto:contact@lead-continuity.com">contact@lead-continuity.com</a></dd>

          <dt>Website</dt>
          <dd><a href="https://lead-continuity.com">lead-continuity.com</a></dd>
        </dl>
      </div>
    </div>
  </section>
</BaseLayout>
